# Copy to sdkconfig.credentials and edit. DO NOT commit sdkconfig.credentials.
# Build with: idf.py -D SDKCONFIG_DEFAULTS="sdkconfig.defaults;sdkconfig.credentials" build

CONFIG_ML_WIFI_SSID="your-wifi-ssid"
CONFIG_ML_WIFI_PASSWORD="your-wifi-password"
CONFIG_ML_TAILSCALE_AUTH_KEY="REPLACE_WITH_TAILSCALE_AUTH_KEY"

# Server must already run on your tailnet. Use Tailscale 100.x IP or MagicDNS name.
# If MagicDNS resolution fails in firmware, use the 100.x IP.
CONFIG_SPEAKER_SERVER_HOST="100.64.0.1"
CONFIG_SPEAKER_SERVER_PORT=5055

# Optional: guarantee server gets WireGuard peer slot first.
CONFIG_ML_PRIORITY_PEER_IP="100.64.0.1"
